<?xml version="1.0"?>
<robot name="my_robot">
  <link name="base_link"/>
  
  <link name="z1_base"/>
  <joint name="base_to_z1" type="fixed">
    <parent link="base_link"/>
    <child link="z1_base"/>
    <origin xyz="0.3487 0.0 0.05" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link"/>
  <joint name="base_to_lidar" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.4197 0.0 0.0" rpy="0 0 1.5708"/> <!-- π/2 ≈ 1.5708 -->
  </joint>

  <link name="rtk_link"/>
  <joint name="base_to_rtk" type="fixed">
    <parent link="base_link"/>
    <child link="rtk_link"/>
    <origin xyz="-0.3485 0.0 0.30" rpy="0 0 0"/>
  </joint>
</robot>